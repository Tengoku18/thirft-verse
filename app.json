{
  "expo": {
    "name": "thriftverse",
    "slug": "thrift-verse",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/logo/fav-icon.png",
    "scheme": "thriftverse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thriftverse.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "We need access to your camera to capture photos of vehicles you want to sell on Thriftverse. For example, when you list a used car or motorcycle, you can take photos directly from your camera to upload to your product listing.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to select and upload photos of vehicles for sale. For example, you can choose existing photos from your gallery when creating or editing a vehicle listing, allowing you to show multiple angles of your car, bike, or e-bike.",
        "NSPhotoLibraryAddOnlyUsageDescription": "We need permission to save photos to your photo library from vehicle listings. For example, you can download photos of vehicles you're interested in buying to your gallery for later reference."
      }
    },
    "android": {
      "package": "com.thriftverse.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/android-icon1.png",
        "backgroundImage": "./assets/logo/android-base1.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/fav-icon.png"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/6c1851d4-a94c-42f6-942c-c2d2f223aaa8"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/splash-screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#C08B7B"
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "thriiftverse"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo/android-icon1.png",
          "color": "#C08B7B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "thriftme",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c1851d4-a94c-42f6-942c-c2d2f223aaa8"
      }
    }
  }
}
